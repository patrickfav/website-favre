{
  "name": "@patrickfav/hugo-content-downloader",
  "version": "1.0.0",
  "description": "A Script that prepares your github readmes and medium posts for Hugo",
  "main": "dist/index.js",
  "bin": {
    "hugo-content-downloader": "./dist/index.js"
  },
  "engines": {
    "node": ">=24.10.0 <25.0.0"
  },
  "packageManager": "pnpm@10.33.1",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "package": "pnpm clean && pnpm install --frozen-lockfile && pnpm build && pnpm test",
    "package:ci": "pnpm install --frozen-lockfile && pnpm build && pnpm test",
    "build": "pnpm exec tsc",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint:ci": "eslint src/**/*.ts -f json -o eslint_report.json",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf ./dist"
  },
  "keywords": [
    "cli",
    "cg-dl"
  ],
  "author": "Patrick Favre",
  "repository": {
    "type": "git",
    "url": "https://github.com/patrickfav/website-favre.git"
  },
  "dependencies": {
    "base32-encoding": "^1.0.0",
    "cheerio": "1.0.0-rc.12",
    "esm": "^3.2.25",
    "file-type": "^22.0.1",
    "firebase-admin": "^10.3.0",
    "got": "^11.8.6",
    "rss-parser": "3.13.0",
    "scramjet": "^4.29.0",
    "turndown": "v7.1.2",
    "turndown-plugin-gfm": "^1.0.2",
    "typescript": "^5.9.3",
    "words-count": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/cheerio": "^0.22.31",
    "@types/esm": "^3.2.0",
    "@types/got": "^9.6.12",
    "@types/jest": "^29.5.4",
    "@types/node": "^18.17.15",
    "@types/turndown": "^5.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "firebase-mock": "^2.3.2",
    "jest": "^29.7.0",
    "sonarqube-scanner": "^3.0.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1"
  }
}
